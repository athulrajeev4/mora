# =============================================================================
# MORA PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://mora_user:mora_password@localhost:5432/mora_db

# -----------------------------------------------------------------------------
# TWILIO (Required) - Voice calling
# -----------------------------------------------------------------------------
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# -----------------------------------------------------------------------------
# PUBLIC URL (Required for webhooks)
# -----------------------------------------------------------------------------
# Use ngrok HTTPS URL (e.g., https://abc123.ngrok-free.app)
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app
USE_DEMO_TWIML=false

# -----------------------------------------------------------------------------
# LIVEKIT (Required for voice agent)
# -----------------------------------------------------------------------------
# Get from: https://cloud.livekit.io/ → Create Project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_secret_key_here

# -----------------------------------------------------------------------------
# DEEPGRAM (Required for STT - Speech-to-Text)
# -----------------------------------------------------------------------------
# Get from: https://deepgram.com/ → API Keys
# Free tier: $200 credit
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# -----------------------------------------------------------------------------
# ELEVENLABS (Required for TTS - Text-to-Speech)
# -----------------------------------------------------------------------------
# Get from: https://elevenlabs.io/ → Profile → API Key
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# -----------------------------------------------------------------------------
# OPENAI (Required for LLM and optional Whisper transcription)
# -----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# GEMINI (Optional - Alternative to OpenAI for evaluation)
# -----------------------------------------------------------------------------
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini  # or "openai"

# =============================================================================
# SETUP CHECKLIST
# =============================================================================
# 
# ✅ 1. PostgreSQL running (docker-compose up -d)
# ✅ 2. Twilio account with verified phone number
# ✅ 3. ngrok tunnel active (ngrok http 8000)
# ✅ 4. LiveKit Cloud project created
# ✅ 5. Deepgram API key obtained (free $200 credit)
# ✅ 6. ElevenLabs API key obtained (free 10K chars)
# ✅ 7. OpenAI API key with credits
# ✅ 8. Optional: Gemini API key for evaluation
# 
# =============================================================================
# RUNNING THE SYSTEM
# =============================================================================
# 
# Terminal 1 - FastAPI Server:
#   cd backend
#   uvicorn app.main:app --reload
# 
# Terminal 2 - LiveKit Agent Worker:
#   cd backend
#   python run_agent.py
# 
# Terminal 3 - ngrok:
#   ngrok http 8000
#   (Copy HTTPS URL to PUBLIC_URL above)
# 
# =============================================================================
# COST ESTIMATES (per test call, ~2 minutes)
# =============================================================================
# 
# Twilio Voice:    $0.026  (2 min × $0.013/min)
# LiveKit:         $0.016  (2 min × $0.008/min)
# Deepgram STT:    $0.009  (2 min × $0.0043/min)
# OpenAI GPT-4:    $0.020  (4 turns × $0.005)
# ElevenLabs TTS:  $0.012  (4 responses × $0.003)
# Gemini Eval:     $0.001  (evaluation only)
# 
# TOTAL PER TEST:  ~$0.084 (~8 cents per full conversation test)
# 
